{{!--
  class.hbs — rendered once per TypeSpec model as `public partial class`.

  Override via tspconfig.yaml:
    options:
      "@massivescale/tsp-aspnetcore-api":
        templates:
          class: "./templates/class.hbs"

  ── Template variables ──────────────────────────────────────────────────────

  {{doc}}             — pre-rendered XML <summary> block (may be falsy).
                        Format: "/// <summary>\n/// ...\n/// </summary>"

  {{className}}       — PascalCase class name, e.g. "UserProfile"

  {{interfaceName}}   — companion interface name, e.g. "IUserProfile"

  {{baseClass}}       — PascalCase base class name if the TypeSpec model uses
                        `extends`; falsy when there is no parent model

  {{bases}}           — comma-joined inheritance list ready for `: <bases>`,
                        e.g. "Animal, IUserProfile"  or just  "IUserProfile".
                        Computed as: [baseClass, interfaceName].filter(Boolean).join(", ")

  {{properties}}      — array of property objects, one per TypeSpec property,
                        in declaration order.  Each object has:
    .doc              —   pre-rendered XML <summary> block (may be falsy)
    .type             —   C# type string, e.g. "string?", "IList<Guid>?", "int"
    .name             —   PascalCase property name, e.g. "FirstName"
    .jsonName         —   camelCase JSON key for [JsonPropertyName], e.g. "firstName"
    .nullable         —   true when the type is nullable (ends with "?");
                          controls whether [JsonIgnore] is emitted

                        Note: the `@discriminator` property (see {{discriminator}}
                        below) is omitted from this list on every class in the
                        hierarchy — it is never a declared C# property, only
                        polymorphic JSON metadata.

  {{propertiesBlock}} — shortcut: all properties pre-rendered (with JSON
                        attributes) joined by blank lines; equivalent to
                        iterating {{properties}} with the default formatting.
                        Pass through {{indent}} to get 4-space indentation.

  {{patchMethod}}     — present only on MergePatch classes. Structured view:
                          .targetType         — C# name of the target entity, e.g. "Pet"
                          .properties[]       — patchable properties (inner type matches entity):
                            .name             —   PascalCase property name
                          .skippedProperties[]— excluded properties (type mismatch):
                            .name             —   PascalCase property name
                            .patchInnerType   —   inner type of MergePatchValue<T>
                            .entityType       —   corresponding entity property type

  {{patchMethodBlock}}— shortcut: the Patch method pre-rendered as a C# method
                        string (4-space indented, no trailing newline). Falsy
                        when the class is not a MergePatch model.

  {{discriminator}}   — present only on models carrying `@discriminator`; drives
                        `[JsonPolymorphic]` / `[JsonDerivedType]` generation.
    .propertyName     —   JSON property name used as the type discriminator,
                          e.g. "kind"
    .derivedTypes[]   —   known derived types, one per discriminator value
      .className      —     PascalCase class name of the derived type
      .discriminatorValue —  wire value identifying the derived type, e.g. "dog"

  ── Built-in helpers ────────────────────────────────────────────────────────

  {{indent <text>}}        — prefixes every non-empty line of <text> with
                             4 spaces; safe to call on multi-line doc strings
  {{#if (isDefined val)}}  — true when val is not undefined (use for numeric
                             values that may legitimately be 0)

  ── Handlebars #each data ────────────────────────────────────────────────────

  Inside {{#each properties}}:
    @index  — 0-based position
    @first  — true on the first iteration
    @last   — true on the last iteration
  Use {{#unless @last}} to add a blank line between properties.

  ── Example customisations ────────────────────────────────────────────────────

  • Add class-level attributes before the declaration:
      [Serializable]
      public partial class {{className}} : {{bases}}

  • Use `internal` or `public sealed` instead of `public partial`.

  • Override the JSON key for a specific property (iterate {{properties}}):
      [JsonPropertyName("my_snake_case")]
      public {{type}} {{name}} { get; set; }

  • Add `= default!;` initialisers to suppress nullable warnings:
      public {{type}} {{name}} { get; set; } = default!;

  • Use init-only setters (C# 9+):
      public {{type}} {{name}} { get; init; }

  • Omit [JsonIgnore] and rely on global JsonSerializerOptions instead:
      [JsonPropertyName("{{jsonName}}")]
      public {{type}} {{name}} { get; set; }

  • Add [JsonRequired] for non-nullable required properties:
      {{#unless nullable}}[JsonRequired]
      {{/unless}}[JsonPropertyName("{{jsonName}}")]
      public {{type}} {{name}} { get; set; }
--}}
{{#if doc}}{{doc}}
{{/if}}{{#if discriminator}}[JsonPolymorphic(TypeDiscriminatorPropertyName = "{{discriminator.propertyName}}")]
{{#each discriminator.derivedTypes}}[JsonDerivedType(typeof({{className}}), "{{discriminatorValue}}")]
{{/each}}{{/if}}[System.Diagnostics.CodeAnalysis.ExcludeFromCodeCoverage]
public partial class {{className}}{{#if bases}} : {{bases}}{{/if}}
{
{{#each properties}}{{#if doc}}{{indent doc}}
{{/if}}    [JsonPropertyName("{{jsonName}}")]
{{#if nullable}}    [JsonIgnore(Condition = JsonIgnoreCondition.WhenWritingNull)]
{{/if}}    public {{type}} {{name}} { get; set; }{{#if initializer}} = {{initializer}};{{/if}}
{{#unless @last}}

{{/unless}}{{/each}}
{{#if patchMethodBlock}}
{{patchMethodBlock}}
{{/if}}
}
