{{!--
  controller.hbs — rendered once per HTTP operation container as an abstract
  ASP.NET Core controller base class.

  Override via tspconfig.yaml:
    options:
      "@massivescale/tsp-aspnetcore-api":
        templates:
          controller: "./templates/controller.hbs"

  ── Template variables ──────────────────────────────────────────────────────

  {{doc}}                  — pre-rendered XML <summary> block (may be falsy)

  {{controllerName}}       — full abstract class name, e.g. "UsersControllerBase"

  {{serviceName}}          — abstract service class name, e.g. "UsersServiceBase"

  {{serviceInterfaceName}} — service interface name, e.g. "IUsersService"

  {{operations}}           — array of operation objects, one per HTTP operation.
                             Each object has:
    .doc                   —   pre-rendered XML <summary> block (may be falsy)
    .name                  —   PascalCase method name, e.g. "GetById"
    .httpVerb              —   PascalCase HTTP verb, e.g. "Get", "Post", "Delete"
    .routes                —   array of absolute route strings for this operation,
                               one per API version, e.g.:
                               ["/api/v1/users/{id}", "/api/v2/users/{id}"]
                               Each becomes its own [HttpVerb("...")] attribute.
    .routeSuffix           —   operation-level @route fragment (informational),
                               e.g. "{id}"; falsy when at the container root
    .returnType            —   C# return type from the 2xx response body,
                               e.g. "User", "IList<Widget>", "object".
                               Not used in the default abstract `IActionResult`
                               return, but available for typed result patterns:
                               `Task<ActionResult<{{returnType}}>>`
    .params                —   array of parameter objects.  Each has:
      .name                —     camelCase parameter name
      .type                —     C# type string (non-nullable), e.g. "string"
      .binding             —     "FromRoute" | "FromQuery" | "FromBody" | "FromHeader"
      .optional            —     boolean; true → render type as `{{type}}?`

  {{actionsBlock}}         — shortcut: all operations pre-rendered (4-space
                             indented, with binding attributes and `abstract`
                             modifier) joined by blank lines.  Use triple-stash
                             {{{actionsBlock}}} to prevent HTML escaping of `<>`.

  ── Built-in helpers ────────────────────────────────────────────────────────

  {{indent <text>}}        — 4-space indent on every non-empty line; use for
                             multi-line doc strings: {{indent doc}}
  {{#if (isDefined val)}}  — true when val is not undefined

  ── Handlebars #each data ───────────────────────────────────────────────────

  Inside {{#each operations}}:  @index, @first, @last
  Inside {{#each routes}}:      @index, @first, @last, {{this}} = route string
  Inside {{#each params}}:      @index, @first, @last

  ── Param rendering quick reference ─────────────────────────────────────────

  Full parameter with binding attribute:
    [{{binding}}] {{#if optional}}{{type}}?{{else}}{{type}}{{/if}} {{name}}

  Comma-separated parameter list:
    {{#each params}}[{{binding}}] {{#if optional}}{{type}}?{{else}}{{type}}{{/if}} {{name}}{{#unless @last}}, {{/unless}}{{/each}}

  ── Example customisations ────────────────────────────────────────────────────

  • Add constructor-based DI so the controller holds a service reference:
      protected {{controllerName}}({{serviceInterfaceName}} service)
      {
          _service = service;
      }
      private readonly {{serviceInterfaceName}} _service;

  • Add [Authorize] for authenticated endpoints:
      [Authorize]
      [ApiController]

  • Add per-operation [Authorize(Roles = "...")] inside the {{#each operations}}
    block before the {{#each routes}} loop.

  • Use typed results instead of IActionResult:
      public abstract Task<ActionResult<{{returnType}}?>> {{name}}(...);

  • Add [ProducesResponseType] attributes per operation:
      [ProducesResponseType(typeof({{returnType}}), StatusCodes.Status200OK)]
      [ProducesResponseType(StatusCodes.Status404NotFound)]
      {{#each routes}}[Http{{../httpVerb}}("{{this}}")]
      {{/each}}

  • Revert to class-level [Route] with relative method suffixes:
      [Route("/api")]
      [ApiController]
      public abstract class {{controllerName}} : ControllerBase
      {
      {{#each operations}}
          [Http{{httpVerb}}{{#if routeSuffix}}("{{routeSuffix}}"){{/if}}]
          ...
      {{/each}}
--}}
{{#if doc}}{{doc}}
{{/if}}[ApiController]
public abstract class {{controllerName}} : ControllerBase
{
{{#each operations}}{{#if doc}}{{indent doc}}
{{/if}}{{#each routes}}    [Http{{../httpVerb}}("{{this}}")]
{{/each}}    public abstract Task<IActionResult> {{name}}({{#each params}}[{{binding}}] {{#if optional}}{{type}}?{{else}}{{type}}{{/if}} {{name}}{{#unless @last}}, {{/unless}}{{/each}});
{{#unless @last}}

{{/unless}}{{/each}}
}
