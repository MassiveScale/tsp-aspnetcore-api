{
  "name": "@massivescale/tsp-aspnetcore-api",
  "version": "0.11.1",
  "type": "module",
  "main": "dist/src/index.js",
  "tspMain": "lib/main.tsp",
  "exports": {
    ".": {
      "typespec": "./lib/main.tsp",
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "peerDependencies": {
    "@typespec/compiler": "^1.13.0",
    "@typespec/http": "^1.13.0",
    "@typespec/versioning": "^0.83.0",
    "@typespec/emitter-framework": "^0.17.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@typespec/compiler": "^1.13.0",
    "@typespec/http": "^1.13.0",
    "@typespec/versioning": "^0.83.0",
    "eslint": "^9.39.4",
    "prettier": "^3.3.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "scripts": {
    "prepare": "tsc && tsc -p tsconfig.test.json && node scripts/copy-templates.mjs",
    "build": "tsc && tsc -p tsconfig.test.json && node scripts/copy-templates.mjs",
    "watch": "tsc --watch",
    "pretest": "npm run build",
    "test": "cd dist && node --test",
    "test:vscode": "node --test test/**/*.test.mjs",
    "lint": "eslint src/ test/ --report-unused-disable-directives --max-warnings=0",
    "lint:fix": "eslint . --report-unused-disable-directives --fix",
    "format": "prettier .  --write",
    "format:check": "prettier --check ."
  },
  "private": true,
  "packageManager": "npm@11.13.0+sha512.7119a16a0843580d65160977520e3f5710c974f04afd4fad36d9eb97d917ba716a856c35c78c4be6dc64367eeaccfb957ef5ce997ca31e9330b2e936ba2b1b92",
  "dependencies": {
    "handlebars": "^4.7.9"
  }
}
